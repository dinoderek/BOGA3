# Optional overrides for local helper scripts.
# Machine setup: `./scripts/boga-config-init.sh` copies this to ~/.config/boga/supabase/cli.env.
# Worktree setup: `./scripts/worktree-setup.sh` symlinks supabase/.env.local -> the global copy.

# Pin or override the CLI used by repo scripts (default matches `supabase/README.md`).
SUPABASE_CLI_VERSION=2.76.15
